<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Demo Products -->
        <record id="product_steel_beam" model="product.product">
            <field name="name">Industrial Steel Beam</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="lst_price">120.0</field>
            <field name="standard_price">100.0</field>
            <field name="type">consu</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
        </record>

        <record id="product_copper_wire" model="product.product">
            <field name="name">High-grade Copper Wire (Roll)</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="lst_price">55.0</field>
            <field name="standard_price">40.0</field>
            <field name="type">consu</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
        </record>

        <record id="product_stationery" model="product.product">
            <field name="name">Bulk Office Stationery Set</field>
            <field name="categ_id" ref="product.product_category_all"/>
            <field name="lst_price">25.0</field>
            <field name="standard_price">18.0</field>
            <field name="type">consu</field>
            <field name="uom_id" ref="uom.product_uom_unit"/>
            <field name="uom_po_id" ref="uom.product_uom_unit"/>
        </record>

        <!-- Demo Vendors -->
        <record id="vendor_acme" model="purchasehub.vendor">
            <field name="company_name">Acme Industrial Materials Ltd</field>
            <field name="gst_number">GSTIN27ACME1234Z</field>
            <field name="vendor_category">raw_materials</field>
            <field name="contact_person">John Doe</field>
            <field name="email">johndoe@acme.example.com</field>
            <field name="phone">+1-555-0199</field>
            <field name="address">123 Industrial Way, Sector 4, Mumbai</field>
            <field name="status">active</field>
        </record>

        <record id="vendor_tech" model="purchasehub.vendor">
            <field name="company_name">Tech Solutions &amp; Electronics</field>
            <field name="gst_number">GSTIN27TECH5678Y</field>
            <field name="vendor_category">electronics</field>
            <field name="contact_person">Alice Smith</field>
            <field name="email">contact@techelectronics.example.com</field>
            <field name="phone">+1-555-0254</field>
            <field name="address">45 Digital Park, Tech Zone, Bangalore</field>
            <field name="status">active</field>
        </record>

        <record id="vendor_office" model="purchasehub.vendor">
            <field name="company_name">Office Supplies Hub</field>
            <field name="gst_number">GSTIN27OFFI0012X</field>
            <field name="vendor_category">office_supplies</field>
            <field name="contact_person">Robert Green</field>
            <field name="email">sales@officesupplies.example.com</field>
            <field name="phone">+1-555-0789</field>
            <field name="address">78 Stationery Road, Commercial Hub, Delhi</field>
            <field name="status">active</field>
        </record>

        <!-- Demo RFQ -->
        <record id="rfq_q3_steel" model="purchasehub.rfq">
            <field name="title">Steel &amp; Wiring Supply for Q3 Production</field>
            <field name="description">Procurement of steel beams and copper wires for our construction expansion phase.</field>
            <field name="deadline" eval="(datetime.date.today() + datetime.timedelta(days=14)).strftime('%Y-%m-%d 18:00:00')"/>
            <field name="state">sent</field>
            <field name="vendor_ids" eval="[(6, 0, [ref('vendor_acme'), ref('vendor_tech')])]"/>
        </record>

        <!-- RFQ Lines -->
        <record id="rfq_line_steel" model="purchasehub.rfq.line">
            <field name="rfq_id" ref="rfq_q3_steel"/>
            <field name="product_id" ref="product_steel_beam"/>
            <field name="description">Steel Beams for structural reinforcement</field>
            <field name="quantity">50.0</field>
        </record>

        <record id="rfq_line_copper" model="purchasehub.rfq.line">
            <field name="rfq_id" ref="rfq_q3_steel"/>
            <field name="product_id" ref="product_copper_wire"/>
            <field name="description">Copper cabling coils</field>
            <field name="quantity">100.0</field>
        </record>

        <!-- Quotation 1 (Acme) -->
        <record id="quote_acme" model="purchasehub.quotation">
            <field name="vendor_id" ref="vendor_acme"/>
            <field name="rfq_id" ref="rfq_q3_steel"/>
            <field name="delivery_days">5</field>
            <field name="notes">We offer premium grade steel with rapid delivery.</field>
            <field name="status">submitted</field>
        </record>

        <record id="quote_line_acme_steel" model="purchasehub.quotation.line">
            <field name="quotation_id" ref="quote_acme"/>
            <field name="rfq_line_id" ref="rfq_line_steel"/>
            <field name="product_id" ref="product_steel_beam"/>
            <field name="quantity">50.0</field>
            <field name="price_unit">110.0</field>
        </record>

        <record id="quote_line_acme_copper" model="purchasehub.quotation.line">
            <field name="quotation_id" ref="quote_acme"/>
            <field name="rfq_line_id" ref="rfq_line_copper"/>
            <field name="product_id" ref="product_copper_wire"/>
            <field name="quantity">100.0</field>
            <field name="price_unit">50.0</field>
        </record>

        <!-- Quotation 2 (Tech Solutions) -->
        <record id="quote_tech" model="purchasehub.quotation">
            <field name="vendor_id" ref="vendor_tech"/>
            <field name="rfq_id" ref="rfq_q3_steel"/>
            <field name="delivery_days">8</field>
            <field name="notes">Competitive pricing on wire imports. Standard delivery terms.</field>
            <field name="status">submitted</field>
        </record>

        <record id="quote_line_tech_steel" model="purchasehub.quotation.line">
            <field name="quotation_id" ref="quote_tech"/>
            <field name="rfq_line_id" ref="rfq_line_steel"/>
            <field name="product_id" ref="product_steel_beam"/>
            <field name="quantity">50.0</field>
            <field name="price_unit">125.0</field>
        </record>

        <record id="quote_line_tech_copper" model="purchasehub.quotation.line">
            <field name="quotation_id" ref="quote_tech"/>
            <field name="rfq_line_id" ref="rfq_line_copper"/>
            <field name="product_id" ref="product_copper_wire"/>
            <field name="quantity">100.0</field>
            <field name="price_unit">42.0</field>
        </record>
    </data>
</odoo>
