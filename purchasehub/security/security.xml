<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record id="module_category_purchasehub" model="ir.module.category">
            <field name="name">PurchaseHub</field>
            <field name="description">Access levels for PurchaseHub Procurement ERP</field>
            <field name="sequence">10</field>
        </record>

        <!-- User Groups -->
        <record id="group_vendor" model="res.groups">
            <field name="name">Vendor</field>
            <field name="category_id" ref="module_category_purchasehub"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="group_officer" model="res.groups">
            <field name="name">Procurement Officer</field>
            <field name="category_id" ref="module_category_purchasehub"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Manager / Approver</field>
            <field name="category_id" ref="module_category_purchasehub"/>
            <field name="implied_ids" eval="[(4, ref('group_officer'))]"/>
        </record>

        <record id="group_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_category_purchasehub"/>
            <field name="implied_ids" eval="[(4, ref('group_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rules for Vendor Isolation -->
        <record id="rule_vendor_profile_own" model="ir.rule">
            <field name="name">Vendors: View Own Profile</field>
            <field name="model_id" ref="model_purchasehub_vendor"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vendor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_vendor_rfq_assigned" model="ir.rule">
            <field name="name">Vendors: View Assigned RFQs</field>
            <field name="model_id" ref="model_purchasehub_rfq"/>
            <field name="domain_force">[('vendor_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vendor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_vendor_quotation_own" model="ir.rule">
            <field name="name">Vendors: Manage Own Quotations</field>
            <field name="model_id" ref="model_purchasehub_quotation"/>
            <field name="domain_force">[('vendor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vendor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_vendor_po_own" model="ir.rule">
            <field name="name">Vendors: View Own Purchase Orders</field>
            <field name="model_id" ref="model_purchasehub_purchase_order"/>
            <field name="domain_force">[('vendor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vendor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_vendor_invoice_own" model="ir.rule">
            <field name="name">Vendors: View Own Invoices</field>
            <field name="model_id" ref="model_purchasehub_invoice"/>
            <field name="domain_force">[('purchase_order_id.vendor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_vendor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
