<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="purchasehub.DashboardTemplate">
        <div class="purchasehub-dashboard container-fluid py-4 bg-light overflow-auto" style="height: 100%;">
            <!-- Header Banner -->
            <div class="d-flex justify-content-between align-items-center mb-4 p-4 text-white rounded-3 shadow-lg" style="background: linear-gradient(135deg, #4a154b 0%, #2b6cb0 100%);">
                <div>
                    <h1 class="fw-bold mb-1">PurchaseHub Procurement Centre</h1>
                    <p class="mb-0 text-white-50">Real-time procurement tracking, quote evaluations, and vendor analytics.</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-light d-flex align-items-center gap-2 fw-semibold px-3" t-on-click="openRfqs">
                        <i class="fa fa-file-text-o"></i> View RFQs
                    </button>
                    <button class="btn btn-light d-flex align-items-center gap-2 fw-semibold px-3 text-primary" t-on-click="openPOs">
                        <i class="fa fa-shopping-cart"></i> View POs
                    </button>
                </div>
            </div>

            <!-- Loader State -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center py-5" style="min-height: 400px;">
                    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </t>

            <!-- Main Stats Grid -->
            <t t-else="">
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
                    <!-- Card 1: Total Vendors -->
                    <div class="col" t-on-click="openVendors" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Total Vendors</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-teal-light text-teal" style="width: 42px; height: 42px; background-color: #e6fffa; color: #319795;">
                                    <i class="fa fa-users fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.total_vendors || 0"/></h2>
                            <p class="text-success small mb-0"><i class="fa fa-check-circle"></i> Onboarded Suppliers</p>
                        </div>
                    </div>

                    <!-- Card 2: Active RFQs -->
                    <div class="col" t-on-click="openRfqs" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Active RFQs</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-blue-light text-blue" style="width: 42px; height: 42px; background-color: #ebf8ff; color: #2b6cb0;">
                                    <i class="fa fa-file-text-o fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.active_rfqs || 0"/></h2>
                            <p class="text-primary small mb-0"><i class="fa fa-clock-o"></i> Under Negotiation</p>
                        </div>
                    </div>

                    <!-- Card 3: Quotations Received -->
                    <div class="col" t-on-click="openQuotations" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Quotes Received</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-purple-light text-purple" style="width: 42px; height: 42px; background-color: #faf5ff; color: #805ad5;">
                                    <i class="fa fa-reply-all fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.quotes_received || 0"/></h2>
                            <p class="text-purple small mb-0"><i class="fa fa-send"></i> Vendor Quotations</p>
                        </div>
                    </div>

                    <!-- Card 4: Pending Approvals -->
                    <div class="col" t-on-click="openQuotations" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Pending Approvals</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-orange-light text-orange" style="width: 42px; height: 42px; background-color: #fffaf0; color: #dd6b20;">
                                    <i class="fa fa-thumbs-o-up fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.pending_approvals || 0"/></h2>
                            <p class="text-warning small mb-0"><i class="fa fa-exclamation-triangle"></i> Manager Attention</p>
                        </div>
                    </div>

                    <!-- Card 5: Approved Quotes -->
                    <div class="col" t-on-click="openQuotations" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Approved Quotes</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-green-light text-green" style="width: 42px; height: 42px; background-color: #f0fff4; color: #38a169;">
                                    <i class="fa fa-check fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.approved_quotes || 0"/></h2>
                            <p class="text-success small mb-0"><i class="fa fa-trophy"></i> Successful Bids</p>
                        </div>
                    </div>

                    <!-- Card 6: Purchase Orders -->
                    <div class="col" t-on-click="openPOs" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Purchase Orders</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-teal-light text-teal" style="width: 42px; height: 42px; background-color: #e6fffa; color: #319795;">
                                    <i class="fa fa-shopping-cart fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.purchase_orders || 0"/></h2>
                            <p class="text-teal small mb-0"><i class="fa fa-check-square-o"></i> Contracted Orders</p>
                        </div>
                    </div>

                    <!-- Card 7: Invoices -->
                    <div class="col" t-on-click="openPOs" style="cursor: pointer;">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Invoices Generated</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-blue-light text-blue" style="width: 42px; height: 42px; background-color: #ebf8ff; color: #2b6cb0;">
                                    <i class="fa fa-file-code-o fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.invoices || 0"/></h2>
                            <p class="text-blue small mb-0"><i class="fa fa-credit-card"></i> Supplier Bills</p>
                        </div>
                    </div>

                    <!-- Card 8: Spend -->
                    <div class="col">
                        <div class="kpi-card shadow-sm border-0 rounded-3 p-3 bg-white h-100" style="background: linear-gradient(135deg, #ffffff 0%, #f7fafc 100%);">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="text-muted fw-semibold uppercase text-xs">Total Spend</span>
                                <div class="icon-container rounded-circle d-flex align-items-center justify-content-center bg-purple-light text-purple" style="width: 42px; height: 42px; background-color: #faf5ff; color: #4a154b;">
                                    <i class="fa fa-money fs-5"></i>
                                </div>
                            </div>
                            <h2 class="fw-bold mb-1 text-dark"><t t-out="state.stats.monthly_spend || 0"/></h2>
                            <p class="text-dark small mb-0"><i class="fa fa-line-chart"></i> Total PO Value</p>
                        </div>
                    </div>
                </div>

                <!-- Charts Layout Grid -->
                <div class="row g-4 mb-4">
                    <!-- Chart 1: Vendor Performance -->
                    <div class="col-md-6 col-lg-8">
                        <div class="card shadow-sm border-0 rounded-3 bg-white p-3 h-100">
                            <div class="card-header border-0 bg-white d-flex align-items-center justify-content-between pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa fa-bar-chart text-success me-2"></i>Top Rated Vendors</h5>
                                <span class="badge bg-success-light text-success small">High Performers</span>
                            </div>
                            <div class="card-body" style="position: relative; height: 320px;">
                                <canvas id="chartVendorPerf"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 2: RFQ Distribution -->
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm border-0 rounded-3 bg-white p-3 h-100">
                            <div class="card-header border-0 bg-white d-flex align-items-center justify-content-between pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa fa-pie-chart text-primary me-2"></i>RFQ Pipeline</h5>
                                <span class="badge bg-primary-light text-primary small">Status Split</span>
                            </div>
                            <div class="card-body" style="position: relative; height: 320px;">
                                <canvas id="chartRfqDist"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Chart 3: Category Spend -->
                    <div class="col-12">
                        <div class="card shadow-sm border-0 rounded-3 bg-white p-3">
                            <div class="card-header border-0 bg-white d-flex align-items-center justify-content-between pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa fa-pie-chart text-warning me-2"></i>Spend Analysis per Category</h5>
                                <span class="badge bg-warning-light text-warning small">Distribution</span>
                            </div>
                            <div class="card-body d-flex justify-content-center align-items-center" style="position: relative; height: 340px;">
                                <div style="width: 100%; max-width: 500px; height: 100%;">
                                    <canvas id="chartCategorySpend"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
