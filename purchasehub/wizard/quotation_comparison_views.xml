<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_purchasehub_quotation_comparison_wizard_form" model="ir.ui.view">
        <field name="name">purchasehub.quotation.comparison.form</field>
        <field name="model">purchasehub.quotation.comparison</field>
        <field name="arch" type="xml">
            <form string="Compare Quotations Matrix">
                <sheet>
                    <group>
                        <field name="rfq_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page name="quotes" string="Candidate Quotations">
                            <field name="quotation_ids" readonly="1">
                                <tree>
                                    <field name="quotation_number"/>
                                    <field name="vendor_id"/>
                                    <field name="quotation_amount"/>
                                    <field name="delivery_days"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page name="recommendation" string="AI Match Recommendation">
                            <group>
                                <field name="recommended_quotation_id" readonly="1"/>
                            </group>
                            <div class="alert alert-info" role="alert" style="white-space: pre-line;">
                                <field name="recommendation_reason" readonly="1"/>
                            </div>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_approve_recommended" string="Approve Recommended Quote" type="object" class="oe_highlight" invisible="not recommended_quotation_id"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Wizard -->
    <record id="action_purchasehub_quotation_comparison_wizard" model="ir.actions.act_window">
        <field name="name">Compare Quotations (Wizard)</field>
        <field name="res_model">purchasehub.quotation.comparison</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
