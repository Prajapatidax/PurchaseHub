<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_quotation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Inter', sans-serif;">
                        <div class="text-center mb-4" style="border-bottom: 2px solid #4a154b; padding-bottom: 10px;">
                            <h2 style="color: #4a154b; font-weight: bold;">Vendor Quotation</h2>
                            <h4 class="text-muted"><t t-out="doc.quotation_number"/></h4>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Vendor Profile:</strong>
                                <address>
                                    <strong><t t-out="doc.vendor_id.company_name"/></strong><br/>
                                    Contact: <t t-out="doc.vendor_id.contact_person"/><br/>
                                    Email: <t t-out="doc.vendor_id.email"/><br/>
                                    Phone: <t t-out="doc.vendor_id.phone"/>
                                </address>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Quotation Overview:</strong>
                                <table class="table table-sm table-borderless float-end">
                                    <tr>
                                        <td><strong>RFQ Ref:</strong></td>
                                        <td><t t-out="doc.rfq_id.rfq_number"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Submission Date:</strong></td>
                                        <td><t t-out="doc.submission_date" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Delivery Days:</strong></td>
                                        <td><t t-out="doc.delivery_days"/> Days</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td><span class="badge bg-success" t-out="doc.status.upper()"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 style="color: #2b6cb0; border-bottom: 1px solid #dee2e6; padding-bottom: 5px;">Quoted Pricing</h5>
                            <table class="table table-striped table-sm mt-2">
                                <thead>
                                    <tr class="table-light">
                                        <th>Product</th>
                                        <th class="text-end">Quantity</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.line_ids" t-as="line">
                                        <td><t t-out="line.product_id.display_name"/></td>
                                        <td class="text-end"><t t-out="line.quantity"/></td>
                                        <td class="text-end"><t t-out="line.price_unit" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        <td class="text-end"><t t-out="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="row justify-content-end mt-3">
                                <div class="col-4">
                                    <table class="table table-sm table-borderless">
                                        <tr class="border-top">
                                            <td><strong>Quoted Total:</strong></td>
                                            <td class="text-end">
                                                <strong><t t-out="doc.quotation_amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></strong>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3" style="border-top: 1px solid #edf2f7;">
                            <strong>Vendor Remarks / Terms:</strong>
                            <p class="text-muted small"><t t-out="doc.notes or 'No special remarks provided.'" class="italic"/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
