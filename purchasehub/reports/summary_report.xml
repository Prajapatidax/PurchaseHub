<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_summary_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page" style="font-family: 'Inter', sans-serif;">
                    <div class="text-center mb-4" style="border-bottom: 2px solid #4a154b; padding-bottom: 10px;">
                        <h2 style="color: #4a154b; font-weight: bold;">Procurement Summary Report</h2>
                        <h5 class="text-muted">Generated on: <t t-out="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/></h5>
                    </div>

                    <h5 style="color: #2b6cb0; border-bottom: 1px solid #dee2e6; padding-bottom: 5px;">Purchase Orders Overview</h5>
                    <table class="table table-striped table-sm mt-3">
                        <thead>
                            <tr class="table-light">
                                <th>PO Number</th>
                                <th>Vendor</th>
                                <th>Quote Ref</th>
                                <th class="text-end">Subtotal</th>
                                <th class="text-end">GST (18%)</th>
                                <th class="text-end">Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_spend" t-value="0.0"/>
                            <t t-set="total_subtotal" t-value="0.0"/>
                            <tr t-foreach="docs" t-as="po">
                                <td><t t-out="po.po_number"/></td>
                                <td><t t-out="po.vendor_id.company_name"/></td>
                                <td><t t-out="po.approved_quotation_id.quotation_number"/></td>
                                <td class="text-end"><t t-out="po.subtotal" t-options='{"widget": "monetary", "display_currency": po.approved_quotation_id.currency_id}'/></td>
                                <td class="text-end"><t t-out="po.tax" t-options='{"widget": "monetary", "display_currency": po.approved_quotation_id.currency_id}'/></td>
                                <td class="text-end"><t t-out="po.total" t-options='{"widget": "monetary", "display_currency": po.approved_quotation_id.currency_id}'/></td>
                                <td><t t-out="po.status.upper()"/></td>
                                <t t-set="total_spend" t-value="total_spend + po.total"/>
                                <t t-set="total_subtotal" t-value="total_subtotal + po.subtotal"/>
                            </tr>
                        </tbody>
                    </table>

                    <div class="row justify-content-end mt-4">
                        <div class="col-4">
                            <table class="table table-sm table-bordered">
                                <tr class="table-light">
                                    <td><strong>Aggregate Subtotal:</strong></td>
                                    <td class="text-end">
                                        <strong><t t-out="total_subtotal" t-options='{"widget": "monetary", "display_currency": docs[0].approved_quotation_id.currency_id if docs else False}'/></strong>
                                    </td>
                                </tr>
                                <tr class="table-light">
                                    <td><strong>Aggregate Spend:</strong></td>
                                    <td class="text-end" style="color: #4a154b;">
                                        <strong><t t-out="total_spend" t-options='{"widget": "monetary", "display_currency": docs[0].approved_quotation_id.currency_id if docs else False}'/></strong>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="mt-5 pt-3" style="border-top: 1px solid #edf2f7;">
                        <strong>Audit Information:</strong>
                        <p class="text-muted small">This is a system generated procurement performance summary. It aggregates transaction volumes and supplier commitments for the selected scope.</p>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
