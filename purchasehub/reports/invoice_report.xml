<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Inter', sans-serif;">
                        <div class="text-center mb-4" style="border-bottom: 2px solid #4a154b; padding-bottom: 10px;">
                            <h2 style="color: #4a154b; font-weight: bold;">Supplier Invoice</h2>
                            <h4 class="text-muted"><t t-out="doc.invoice_number"/></h4>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Billed From:</strong>
                                <address>
                                    <strong><t t-out="doc.purchase_order_id.vendor_id.company_name"/></strong><br/>
                                    Contact: <t t-out="doc.purchase_order_id.vendor_id.contact_person"/><br/>
                                    Email: <t t-out="doc.purchase_order_id.vendor_id.email"/><br/>
                                    Phone: <t t-out="doc.purchase_order_id.vendor_id.phone"/><br/>
                                    Address: <t t-out="doc.purchase_order_id.vendor_id.address"/>
                                </address>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Billing Details:</strong>
                                <table class="table table-sm table-borderless float-end">
                                    <tr>
                                        <td><strong>Invoice Reference:</strong></td>
                                        <td><strong><t t-out="doc.invoice_number"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Invoice Date:</strong></td>
                                        <td><t t-out="doc.invoice_date"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>PO Reference:</strong></td>
                                        <td><t t-out="doc.purchase_order_id.po_number"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Payment Status:</strong></td>
                                        <td>
                                            <span class="badge bg-success" t-if="doc.payment_status == 'paid'">Paid</span>
                                            <span class="badge bg-warning text-dark" t-if="doc.payment_status == 'partially_paid'">Partially Paid</span>
                                            <span class="badge bg-danger" t-if="doc.payment_status == 'unpaid'">Unpaid</span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 style="color: #2b6cb0; border-bottom: 1px solid #dee2e6; padding-bottom: 5px;">Invoice Line Details</h5>
                            <table class="table table-striped table-sm mt-2">
                                <thead>
                                    <tr class="table-light">
                                        <th>Product</th>
                                        <th>Description</th>
                                        <th class="text-end">Quantity</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.line_ids" t-as="line">
                                        <td><t t-out="line.product_id.display_name"/></td>
                                        <td><t t-out="line.description"/></td>
                                        <td class="text-end"><t t-out="line.quantity"/></td>
                                        <td class="text-end"><t t-out="line.price_unit" t-options='{"widget": "monetary", "display_currency": doc.purchase_order_id.approved_quotation_id.currency_id}'/></td>
                                        <td class="text-end"><t t-out="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": doc.purchase_order_id.approved_quotation_id.currency_id}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                            
                            <div class="row justify-content-end mt-3">
                                <div class="col-4">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td><strong>Subtotal:</strong></td>
                                            <td class="text-end">
                                                <t t-out="doc.subtotal" t-options='{"widget": "monetary", "display_currency": doc.purchase_order_id.approved_quotation_id.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Tax (18% GST):</strong></td>
                                            <td class="text-end">
                                                <t t-out="doc.tax" t-options='{"widget": "monetary", "display_currency": doc.purchase_order_id.approved_quotation_id.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr class="border-top">
                                            <td><strong>Grand Total:</strong></td>
                                            <td class="text-end">
                                                <strong><t t-out="doc.grand_total" t-options='{"widget": "monetary", "display_currency": doc.purchase_order_id.approved_quotation_id.currency_id}'/></strong>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-3" style="border-top: 1px solid #edf2f7; text-align: center;">
                            <p class="text-muted small">Thank you for your business. For any invoice queries, contact accounting@purchasehub.com.</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
