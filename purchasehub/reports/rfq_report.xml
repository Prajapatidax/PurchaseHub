<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_rfq_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Inter', sans-serif;">
                        <div class="text-center mb-4" style="border-bottom: 2px solid #4a154b; padding-bottom: 10px;">
                            <h2 style="color: #4a154b; font-weight: bold;">Request for Quotation</h2>
                            <h4 class="text-muted"><t t-out="doc.rfq_number"/></h4>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>RFQ Details:</strong>
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Title:</strong></td>
                                        <td><t t-out="doc.title"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Deadline:</strong></td>
                                        <td><strong class="text-danger"><t t-out="doc.deadline"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Officer:</strong></td>
                                        <td><t t-out="doc.procurement_officer.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td><span class="badge bg-info" t-out="doc.state.upper()"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <strong>Assigned Vendors:</strong>
                                <ul class="list-unstyled">
                                    <li t-foreach="doc.vendor_ids" t-as="vendor">
                                        <i class="fa fa-check text-success"></i> <t t-out="vendor.company_name"/> (<t t-out="vendor.vendor_code"/>)
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 style="color: #2b6cb0; border-bottom: 1px solid #dee2e6; padding-bottom: 5px;">Requested Items List</h5>
                            <table class="table table-striped table-sm mt-2">
                                <thead>
                                    <tr class="table-light">
                                        <th>Product</th>
                                        <th>Description</th>
                                        <th class="text-end">Quantity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.line_ids" t-as="line">
                                        <td><t t-out="line.product_id.display_name"/></td>
                                        <td><t t-out="line.description"/></td>
                                        <td class="text-end"><t t-out="line.quantity"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4 pt-3" style="border-top: 1px solid #edf2f7;">
                            <strong>Instructions:</strong>
                            <p class="text-muted small">Please submit your pricing, lead time, and any exclusions against this request through the vendor portal. Ensure quotes are uploaded before the specified deadline.</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
