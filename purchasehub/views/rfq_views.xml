<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- RFQ Tree View -->
    <record id="view_purchasehub_rfq_tree" model="ir.ui.view">
        <field name="name">purchasehub.rfq.tree</field>
        <field name="model">purchasehub.rfq</field>
        <field name="arch" type="xml">
            <tree string="RFQs" decoration-info="state == 'draft'" decoration-warning="state == 'sent'" decoration-success="state == 'quotation_received'">
                <field name="rfq_number"/>
                <field name="title"/>
                <field name="deadline"/>
                <field name="procurement_officer"/>
                <field name="quotation_count"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'sent'" decoration-success="state == 'quotation_received'" decoration-muted="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <!-- RFQ Form View -->
    <record id="view_purchasehub_rfq_form" model="ir.ui.view">
        <field name="name">purchasehub.rfq.form</field>
        <field name="model">purchasehub.rfq</field>
        <field name="arch" type="xml">
            <form string="Request for Quotation">
                <header>
                    <button name="action_send_rfq" string="Send RFQ" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_receive_quotations" string="Quotations Received" type="object" class="oe_highlight" invisible="state != 'sent'"/>
                    <button name="action_compare_quotations" string="Compare Quotations" type="object" class="oe_highlight" invisible="state not in ['sent', 'quotation_received']"/>
                    <button name="action_close" string="Close RFQ" type="object" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,quotation_received,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="title" class="oe_edit_only"/>
                        <h1>
                            <field name="title" placeholder="e.g. Raw Materials for Q3 Production"/>
                        </h1>
                        <h3>
                            <field name="rfq_number" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group name="procurement_info" string="Procurement Details">
                            <field name="procurement_officer" options="{'no_create': True}"/>
                            <field name="deadline"/>
                        </group>
                        <group name="vendor_info" string="Vendors Assigned">
                            <field name="vendor_ids" widget="many2many_tags" placeholder="Select vendors..."/>
                            <field name="quotation_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="lines" string="Requested Items">
                            <field name="line_ids" mode="tree">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <!-- empty space or placeholder -->
                            </group>
                            <field name="description" placeholder="Additional requirements or terms..."/>
                        </page>
                        <page name="quotes" string="Submitted Quotations">
                            <field name="quotation_ids" readonly="1">
                                <tree>
                                    <field name="quotation_number"/>
                                    <field name="vendor_id"/>
                                    <field name="quotation_amount"/>
                                    <field name="delivery_days"/>
                                    <field name="submission_date"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- RFQ Kanban View -->
    <record id="view_purchasehub_rfq_kanban" model="ir.ui.view">
        <field name="name">purchasehub.rfq.kanban</field>
        <field name="model">purchasehub.rfq</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_show_cards">
                <field name="id"/>
                <field name="rfq_number"/>
                <field name="title"/>
                <field name="deadline"/>
                <field name="state"/>
                <field name="quotation_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-3 mb-2 border rounded shadow-sm bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong class="o_kanban_record_title text-primary"><field name="title"/></strong>
                            </div>
                            <div class="text-muted small">
                                <span>Ref: <field name="rfq_number"/></span>
                            </div>
                            <div class="text-muted small mt-1">
                                <span>Deadline: <field name="deadline"/></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                                <span class="badge badge-secondary"><t t-out="record.quotation_count.raw_value"/> Quotes</span>
                                <field name="procurement_officer" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- RFQ Search View -->
    <record id="view_purchasehub_rfq_search" model="ir.ui.view">
        <field name="name">purchasehub.rfq.search</field>
        <field name="model">purchasehub.rfq</field>
        <field name="arch" type="xml">
            <search string="Search RFQs">
                <field name="title"/>
                <field name="rfq_number"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Sent" name="state_sent" domain="[('state', '=', 'sent')]"/>
                <filter string="Quotations Received" name="state_received" domain="[('state', '=', 'quotation_received')]"/>
                <filter string="Closed" name="state_closed" domain="[('state', '=', 'closed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Procurement Officer" name="group_by_officer" context="{'group_by': 'procurement_officer'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for RFQs -->
    <record id="action_purchasehub_rfq" model="ir.actions.act_window">
        <field name="name">Requests for Quotations</field>
        <field name="res_model">purchasehub.rfq</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_purchasehub_rfq_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first RFQ!
            </p>
            <p>
                Draft procurement needs, assign vendors, receive and compare quotations.
            </p>
        </field>
    </record>
</odoo>
