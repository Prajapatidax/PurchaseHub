<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Order Tree View -->
    <record id="view_purchasehub_purchase_order_tree" model="ir.ui.view">
        <field name="name">purchasehub.purchase.order.tree</field>
        <field name="model">purchasehub.purchase.order</field>
        <field name="arch" type="xml">
            <tree string="Purchase Orders" decoration-info="status == 'draft'" decoration-success="status == 'confirmed'" decoration-muted="status == 'done'" decoration-danger="status == 'cancelled'">
                <field name="po_number"/>
                <field name="approved_quotation_id"/>
                <field name="vendor_id"/>
                <field name="subtotal"/>
                <field name="tax"/>
                <field name="total"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'confirmed'" decoration-muted="status == 'done'" decoration-danger="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Purchase Order Form View -->
    <record id="view_purchasehub_purchase_order_form" model="ir.ui.view">
        <field name="name">purchasehub.purchase.order.form</field>
        <field name="model">purchasehub.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_confirm" string="Confirm Order" type="object" class="oe_highlight" invisible="status != 'draft'" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <button name="action_done" string="Mark Done" type="object" class="oe_highlight" invisible="status != 'confirmed'" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <button name="action_cancel" string="Cancel Order" type="object" invisible="status not in ['draft', 'confirmed']" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="po_number" class="oe_edit_only"/>
                        <h1>
                            <field name="po_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="order_details" string="Order Details">
                            <field name="approved_quotation_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group name="financial_summary" string="Financial Overview">
                            <field name="subtotal" readonly="1"/>
                            <field name="tax" readonly="1"/>
                            <field name="total" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="lines" string="Order Items">
                            <field name="line_ids" mode="tree" readonly="status != 'draft'">
                                <tree editable="bottom">
                                    <field name="product_id" readonly="1"/>
                                    <field name="description"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="price_subtotal" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="subtotal" readonly="1"/>
                                <field name="tax" readonly="1"/>
                                <field name="total" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page name="invoices" string="Associated Invoices">
                            <field name="invoice_ids" readonly="1">
                                <tree>
                                    <field name="invoice_number"/>
                                    <field name="invoice_date"/>
                                    <field name="grand_total"/>
                                    <field name="payment_status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Purchase Order Search View -->
    <record id="view_purchasehub_purchase_order_search" model="ir.ui.view">
        <field name="name">purchasehub.purchase.order.search</field>
        <field name="model">purchasehub.purchase.order</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Orders">
                <field name="po_number"/>
                <field name="vendor_id"/>
                <separator/>
                <filter string="Draft PO" name="status_draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Confirmed" name="status_confirmed" domain="[('status', '=', 'confirmed')]"/>
                <filter string="Done" name="status_done" domain="[('status', '=', 'done')]"/>
                <filter string="Cancelled" name="status_cancelled" domain="[('status', '=', 'cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="group_by_vendor" context="{'group_by': 'vendor_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Purchase Orders -->
    <record id="action_purchasehub_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">purchasehub.purchase.order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_purchasehub_purchase_order_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Purchase Orders created yet.
            </p>
            <p>
                Once a vendor quotation is approved by a manager, a Purchase Order is automatically generated in draft state.
            </p>
        </field>
    </record>
</odoo>
