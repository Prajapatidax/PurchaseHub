<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vendor Tree View -->
    <record id="view_purchasehub_vendor_tree" model="ir.ui.view">
        <field name="name">purchasehub.vendor.tree</field>
        <field name="model">purchasehub.vendor</field>
        <field name="arch" type="xml">
            <tree string="Vendors" decoration-danger="status == 'blacklisted'" decoration-muted="status == 'inactive'" decoration-success="status == 'active'">
                <field name="vendor_code"/>
                <field name="company_name"/>
                <field name="contact_person"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="vendor_category"/>
                <field name="rating" widget="priority"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'inactive'" decoration-danger="status == 'blacklisted'"/>
            </tree>
        </field>
    </record>

    <!-- Vendor Form View -->
    <record id="view_purchasehub_vendor_form" model="ir.ui.view">
        <field name="name">purchasehub.vendor.form</field>
        <field name="model">purchasehub.vendor</field>
        <field name="arch" type="xml">
            <form string="Vendor Profile">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive,blacklisted" clickable="True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="company_name" class="oe_edit_only"/>
                        <h1>
                            <field name="company_name" placeholder="e.g. Acme Corporation"/>
                        </h1>
                        <h3>
                            <field name="vendor_code" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group name="contact_info" string="Contact Details">
                            <field name="contact_person"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="address" placeholder="Billing &amp; Shipping Address..."/>
                        </group>
                        <group name="metadata" string="Vendor Metadata">
                            <field name="vendor_category"/>
                            <field name="gst_number"/>
                            <field name="rating" widget="priority" readonly="1"/>
                            <field name="user_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="quotes" string="Quotation History">
                            <field name="quotation_ids" readonly="1">
                                <tree>
                                    <field name="quotation_number"/>
                                    <field name="rfq_id"/>
                                    <field name="quotation_amount"/>
                                    <field name="delivery_days"/>
                                    <field name="submission_date"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vendor Kanban View -->
    <record id="view_purchasehub_vendor_kanban" model="ir.ui.view">
        <field name="name">purchasehub.vendor.kanban</field>
        <field name="model">purchasehub.vendor</field>
        <field name="arch" type="xml">
            <kanban default_group_by="vendor_category" class="o_kanban_small_show_cards">
                <field name="id"/>
                <field name="company_name"/>
                <field name="vendor_code"/>
                <field name="rating"/>
                <field name="status"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-3 mb-2 border rounded shadow-sm bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong class="o_kanban_record_title text-primary"><field name="company_name"/></strong>
                                <span class="badge" t-attf-class="badge-{{ record.status.raw_value == 'active' ? 'success' : (record.status.raw_value == 'inactive' ? 'secondary' : 'danger') }}">
                                    <field name="status"/>
                                </span>
                            </div>
                            <div class="text-muted small mb-2">
                                <span>Code: <field name="vendor_code"/></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                <span class="small text-muted"><field name="contact_person"/></span>
                                <field name="rating" widget="priority" readonly="1"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vendor Search View -->
    <record id="view_purchasehub_vendor_search" model="ir.ui.view">
        <field name="name">purchasehub.vendor.search</field>
        <field name="model">purchasehub.vendor</field>
        <field name="arch" type="xml">
            <search string="Search Vendors">
                <field name="company_name"/>
                <field name="vendor_code"/>
                <field name="email"/>
                <field name="gst_number"/>
                <separator/>
                <filter string="Active" name="status_active" domain="[('status', '=', 'active')]"/>
                <filter string="Inactive" name="status_inactive" domain="[('status', '=', 'inactive')]"/>
                <filter string="Blacklisted" name="status_blacklisted" domain="[('status', '=', 'blacklisted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by': 'vendor_category'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Vendors -->
    <record id="action_purchasehub_vendor" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">purchasehub.vendor</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_purchasehub_vendor_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vendor!
            </p>
            <p>
                Manage supplier profiles, contact details, categories, and evaluate performance.
            </p>
        </field>
    </record>
</odoo>
