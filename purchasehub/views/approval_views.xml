<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Approval Tree View -->
    <record id="view_purchasehub_approval_tree" model="ir.ui.view">
        <field name="name">purchasehub.approval.tree</field>
        <field name="model">purchasehub.approval</field>
        <field name="arch" type="xml">
            <tree string="Approvals" create="false" edit="false">
                <field name="approval_number"/>
                <field name="quotation_id"/>
                <field name="approver_id"/>
                <field name="approval_date"/>
                <field name="remarks"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'" decoration-warning="state == 'pending'"/>
            </tree>
        </field>
    </record>

    <!-- Approval Form View -->
    <record id="view_purchasehub_approval_form" model="ir.ui.view">
        <field name="name">purchasehub.approval.form</field>
        <field name="model">purchasehub.approval</field>
        <field name="arch" type="xml">
            <form string="Procurement Approval" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <label for="approval_number" class="oe_edit_only"/>
                        <h1>
                            <field name="approval_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="quotation_details" string="Quotation Info">
                            <field name="quotation_id" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                        <group name="approver_details" string="Approver Details">
                            <field name="approver_id" readonly="1"/>
                            <field name="state" readonly="1" widget="badge" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
                        </group>
                    </group>
                    <group name="remarks_group" string="Remarks">
                        <field name="remarks" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Approval Search View -->
    <record id="view_purchasehub_approval_search" model="ir.ui.view">
        <field name="name">purchasehub.approval.search</field>
        <field name="model">purchasehub.approval</field>
        <field name="arch" type="xml">
            <search string="Search Approvals">
                <field name="approval_number"/>
                <field name="quotation_id"/>
                <field name="approver_id"/>
                <separator/>
                <filter string="Approved" name="state_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Approver" name="group_by_approver" context="{'group_by': 'approver_id'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Approvals -->
    <record id="action_purchasehub_approval" model="ir.actions.act_window">
        <field name="name">Approvals</field>
        <field name="res_model">purchasehub.approval</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_purchasehub_approval_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approvals logged yet.
            </p>
            <p>
                Approvals are logged automatically when managers approve or reject quotations.
            </p>
        </field>
    </record>
</odoo>
