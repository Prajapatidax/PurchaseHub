<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Invoice Tree View -->
    <record id="view_purchasehub_invoice_tree" model="ir.ui.view">
        <field name="name">purchasehub.invoice.tree</field>
        <field name="model">purchasehub.invoice</field>
        <field name="arch" type="xml">
            <tree string="Invoices" decoration-danger="payment_status == 'unpaid'" decoration-warning="payment_status == 'partially_paid'" decoration-success="payment_status == 'paid'">
                <field name="invoice_number"/>
                <field name="purchase_order_id"/>
                <field name="invoice_date"/>
                <field name="subtotal"/>
                <field name="tax"/>
                <field name="grand_total"/>
                <field name="payment_status" widget="badge" decoration-danger="payment_status == 'unpaid'" decoration-warning="payment_status == 'partially_paid'" decoration-success="payment_status == 'paid'"/>
            </tree>
        </field>
    </record>

    <!-- Invoice Form View -->
    <record id="view_purchasehub_invoice_form" model="ir.ui.view">
        <field name="name">purchasehub.invoice.form</field>
        <field name="model">purchasehub.invoice</field>
        <field name="arch" type="xml">
            <form string="Supplier Invoice">
                <header>
                    <button name="action_register_payment" string="Register Payment" type="object" class="oe_highlight" invisible="payment_status == 'paid'" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <button name="action_register_partial_payment" string="Register Partial Payment" type="object" invisible="payment_status in ['paid', 'partially_paid']" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <button name="action_send_invoice" string="Send Email" type="object" class="oe_highlight" groups="purchasehub.group_officer,purchasehub.group_manager"/>
                    <field name="payment_status" widget="statusbar" statusbar_visible="unpaid,partially_paid,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="invoice_number" class="oe_edit_only"/>
                        <h1>
                            <field name="invoice_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="invoice_details" string="Invoice Details">
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="invoice_date" readonly="payment_status == 'paid'"/>
                        </group>
                        <group name="financials" string="Billing Summary">
                            <field name="subtotal" readonly="1"/>
                            <field name="tax" readonly="1"/>
                            <field name="grand_total" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="lines" string="Invoice Items">
                            <field name="line_ids" mode="tree" readonly="payment_status == 'paid'">
                                <tree editable="bottom">
                                    <field name="product_id" readonly="1"/>
                                    <field name="description"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="price_subtotal" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="subtotal" readonly="1"/>
                                <field name="tax" readonly="1"/>
                                <field name="grand_total" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Invoice Search View -->
    <record id="view_purchasehub_invoice_search" model="ir.ui.view">
        <field name="name">purchasehub.invoice.search</field>
        <field name="model">purchasehub.invoice</field>
        <field name="arch" type="xml">
            <search string="Search Invoices">
                <field name="invoice_number"/>
                <field name="purchase_order_id"/>
                <separator/>
                <filter string="Unpaid" name="status_unpaid" domain="[('payment_status', '=', 'unpaid')]"/>
                <filter string="Partially Paid" name="status_partially" domain="[('payment_status', '=', 'partially_paid')]"/>
                <filter string="Paid" name="status_paid" domain="[('payment_status', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Purchase Order" name="group_by_po" context="{'group_by': 'purchase_order_id'}"/>
                    <filter string="Payment Status" name="group_by_status" context="{'group_by': 'payment_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Invoices -->
    <record id="action_purchasehub_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">purchasehub.invoice</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_purchasehub_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Invoices logged yet.
            </p>
            <p>
                Invoices are generated automatically when a Purchase Order is confirmed.
            </p>
        </field>
    </record>
</odoo>
