<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 1. RFQ Invitation Email Template -->
        <record id="email_template_rfq_invitation" model="mail.template">
            <field name="name">RFQ Invitation</field>
            <field name="model_id" ref="model_purchasehub_rfq"/>
            <field name="subject">Invitation to Quote: {{ object.rfq_number }} - {{ object.title }}</field>
            <field name="email_to">{{ object.env['purchasehub.vendor'].browse(ctx.get('vendor_id')).email if ctx.get('vendor_id') else '' }}</field>
            <field name="body_html" type="html">
                <div style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; color: #1a202c; max-width: 600px; margin: auto; padding: 25px; border: 1px solid #e2e8f0; border-radius: 12px; background-color: #ffffff; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
                    <div style="text-align: center; border-bottom: 2px solid #edf2f7; padding-bottom: 15px; margin-bottom: 20px;">
                        <h2 style="color: #4a154b; margin: 0; font-size: 24px; font-weight: 700;">PurchaseHub Procurement</h2>
                    </div>
                    <p>Dear <strong style="color: #4a154b;"><t t-out="object.env['purchasehub.vendor'].browse(ctx.get('vendor_id')).company_name"/></strong>,</p>
                    <p>You have been invited to submit a quotation for the following Request for Quotation (RFQ):</p>
                    <div style="background-color: #f7fafc; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #4a154b;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 4px 0; color: #718096; width: 35%;"><strong>RFQ Number:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.rfq_number"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Title:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.title"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Deadline:</strong></td>
                                <td style="padding: 4px 0; color: #e53e3e; font-weight: bold;"><t t-out="object.deadline"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Officer:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.procurement_officer.name"/></td>
                            </tr>
                        </table>
                    </div>
                    <p>Please log in to the portal to submit your quotation before the deadline. Ensure you specify delivery days and your best pricing for all items listed.</p>
                    <p style="margin-top: 25px; font-size: 13px; color: #a0aec0; text-align: center; border-top: 1px solid #edf2f7; padding-top: 15px;">
                        This is an automated notification from PurchaseHub ERP.
                    </p>
                </div>
            </field>
        </record>

        <!-- 2. Quotation Submission Notification -->
        <record id="email_template_quotation_submission" model="mail.template">
            <field name="name">Quotation Submission Notification</field>
            <field name="model_id" ref="model_purchasehub_quotation"/>
            <field name="subject">New Quotation Submitted: {{ object.quotation_number }} for {{ object.rfq_id.rfq_number }}</field>
            <field name="email_to">{{ object.rfq_id.procurement_officer.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; color: #1a202c; max-width: 600px; margin: auto; padding: 25px; border: 1px solid #e2e8f0; border-radius: 12px; background-color: #ffffff;">
                    <div style="text-align: center; border-bottom: 2px solid #edf2f7; padding-bottom: 15px; margin-bottom: 20px;">
                        <h2 style="color: #2b6cb0; margin: 0; font-size: 24px; font-weight: 700;">PurchaseHub Notifications</h2>
                    </div>
                    <p>Hello <strong style="color: #2b6cb0;"><t t-out="object.rfq_id.procurement_officer.name"/></strong>,</p>
                    <p>A new quotation has been successfully submitted by a vendor. Please review and proceed to the comparison step:</p>
                    <div style="background-color: #f7fafc; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #2b6cb0;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 4px 0; color: #718096; width: 40%;"><strong>Quotation Number:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.quotation_number"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Vendor:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.vendor_id.company_name"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Quotation Amount:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748; font-weight: bold;"><t t-out="object.quotation_amount"/> <t t-out="object.currency_id.symbol"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Lead Time (Days):</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.delivery_days"/> days</td>
                            </tr>
                        </table>
                    </div>
                    <p>Use the Odoo comparison engine to analyze the quotes side-by-side and highlight recommendations.</p>
                    <p style="margin-top: 25px; font-size: 13px; color: #a0aec0; text-align: center; border-top: 1px solid #edf2f7; padding-top: 15px;">
                        PurchaseHub Automated Notification.
                    </p>
                </div>
            </field>
        </record>

        <!-- 3. Approval / Rejection Notification -->
        <record id="email_template_approval_status" model="mail.template">
            <field name="name">Quotation Approval Status</field>
            <field name="model_id" ref="model_purchasehub_quotation"/>
            <field name="subject">Status Update: Quotation {{ object.quotation_number }} - {{ object.status.upper() }}</field>
            <field name="email_to">{{ object.vendor_id.email }}</field>
            <field name="body_html" type="html">
                <div style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; color: #1a202c; max-width: 600px; margin: auto; padding: 25px; border: 1px solid #e2e8f0; border-radius: 12px; background-color: #ffffff;">
                    <div style="text-align: center; border-bottom: 2px solid #edf2f7; padding-bottom: 15px; margin-bottom: 20px;">
                        <h2 style="color: #2f855a; margin: 0; font-size: 24px; font-weight: 700;">PurchaseHub Quotation Review</h2>
                    </div>
                    <p>Dear <strong style="color: #2f855a;"><t t-out="object.vendor_id.company_name"/></strong>,</p>
                    <p>We are writing to notify you that your quotation <strong style="color: #2d3748;"><t t-out="object.quotation_number"/></strong> for RFQ <strong style="color: #2d3748;"><t t-out="object.rfq_id.rfq_number"/></strong> has been evaluated.</p>
                    
                    <t t-if="object.status == 'approved'">
                        <div style="background-color: #f0fff4; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #38a169; color: #276749;">
                            <strong>APPROVED:</strong> Your quotation has been accepted! A Purchase Order (PO) has been generated and is being processed by our procurement team.
                        </div>
                    </t>
                    <t t-else="">
                        <div style="background-color: #fff5f5; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #e53e3e; color: #9b2c2c;">
                            <strong>REJECTED:</strong> We regret to inform you that your quotation has not been accepted for this specific request. We thank you for your submission and look forward to working with you on future RFQs.
                        </div>
                    </t>

                    <p>Please contact the procurement officer (<t t-out="object.rfq_id.procurement_officer.name"/>) if you have any questions.</p>
                    <p style="margin-top: 25px; font-size: 13px; color: #a0aec0; text-align: center; border-top: 1px solid #edf2f7; padding-top: 15px;">
                        PurchaseHub Notification.
                    </p>
                </div>
            </field>
        </record>

        <!-- 4. Purchase Order Confirmation Email Template -->
        <record id="email_template_po_confirmation" model="mail.template">
            <field name="name">PO Confirmation</field>
            <field name="model_id" ref="model_purchasehub_purchase_order"/>
            <field name="subject">Purchase Order Confirmed: {{ object.po_number }}</field>
            <field name="email_to">{{ object.vendor_id.email }}</field>
            <field name="report_template_ids" eval="[(4, ref('action_report_purchase_order'))]"/>
            <field name="body_html" type="html">
                <div style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; color: #1a202c; max-width: 600px; margin: auto; padding: 25px; border: 1px solid #e2e8f0; border-radius: 12px; background-color: #ffffff;">
                    <div style="text-align: center; border-bottom: 2px solid #edf2f7; padding-bottom: 15px; margin-bottom: 20px;">
                        <h2 style="color: #319795; margin: 0; font-size: 24px; font-weight: 700;">Purchase Order Dispatch</h2>
                    </div>
                    <p>Dear <strong style="color: #319795;"><t t-out="object.vendor_id.company_name"/></strong>,</p>
                    <p>Please find attached our official Purchase Order <strong style="color: #2d3748;"><t t-out="object.po_number"/></strong> confirming the procurement transaction:</p>
                    <div style="background-color: #f7fafc; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #319795;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 4px 0; color: #718096; width: 40%;"><strong>PO Reference:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.po_number"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Subtotal:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.subtotal"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>GST (18%):</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.tax"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Total Amount:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748; font-weight: bold;"><t t-out="object.total"/></td>
                            </tr>
                        </table>
                    </div>
                    <p>An invoice has been generated for your record. Please arrange delivery in accordance with the quoted timeline.</p>
                    <p style="margin-top: 25px; font-size: 13px; color: #a0aec0; text-align: center; border-top: 1px solid #edf2f7; padding-top: 15px;">
                        PurchaseHub ERP System.
                    </p>
                </div>
            </field>
        </record>

        <!-- 5. Invoice Delivery Email Template -->
        <record id="email_template_invoice_delivery" model="mail.template">
            <field name="name">Invoice Delivery</field>
            <field name="model_id" ref="model_purchasehub_invoice"/>
            <field name="subject">Invoice Delivered: {{ object.invoice_number }} for PO {{ object.purchase_order_id.po_number }}</field>
            <field name="email_to">{{ object.purchase_order_id.vendor_id.email }}</field>
            <field name="report_template_ids" eval="[(4, ref('action_report_invoice'))]"/>
            <field name="body_html" type="html">
                <div style="font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 15px; color: #1a202c; max-width: 600px; margin: auto; padding: 25px; border: 1px solid #e2e8f0; border-radius: 12px; background-color: #ffffff;">
                    <div style="text-align: center; border-bottom: 2px solid #edf2f7; padding-bottom: 15px; margin-bottom: 20px;">
                        <h2 style="color: #4a5568; margin: 0; font-size: 24px; font-weight: 700;">PurchaseHub Billing</h2>
                    </div>
                    <p>Dear <strong style="color: #4a5568;"><t t-out="object.purchase_order_id.vendor_id.company_name"/></strong>,</p>
                    <p>Your invoice <strong style="color: #2d3748;"><t t-out="object.invoice_number"/></strong> relating to Purchase Order <strong style="color: #2d3748;"><t t-out="object.purchase_order_id.po_number"/></strong> has been issued.</p>
                    <div style="background-color: #f7fafc; padding: 15px; border-radius: 8px; margin: 15px 0; border-left: 4px solid #4a5568;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 4px 0; color: #718096; width: 40%;"><strong>Invoice Number:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.invoice_number"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Invoice Date:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748;"><t t-out="object.invoice_date"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Grand Total:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748; font-weight: bold;"><t t-out="object.grand_total"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 0; color: #718096;"><strong>Payment Status:</strong></td>
                                <td style="padding: 4px 0; color: #2d3748; text-transform: uppercase;"><strong><t t-out="object.payment_status"/></strong></td>
                            </tr>
                        </table>
                    </div>
                    <p>The PDF copy of the invoice is attached. Please contact support if there are discrepancies.</p>
                    <p style="margin-top: 25px; font-size: 13px; color: #a0aec0; text-align: center; border-top: 1px solid #edf2f7; padding-top: 15px;">
                        PurchaseHub ERP System.
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>
