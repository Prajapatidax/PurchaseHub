<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Vendor Code Sequence -->
        <record id="seq_purchasehub_vendor" model="ir.sequence">
            <field name="name">Vendor Code</field>
            <field name="code">purchasehub.vendor.sequence</field>
            <field name="prefix">VND</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- RFQ Number Sequence -->
        <record id="seq_purchasehub_rfq" model="ir.sequence">
            <field name="name">RFQ Number</field>
            <field name="code">purchasehub.rfq.sequence</field>
            <field name="prefix">RFQ</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Quotation Number Sequence -->
        <record id="seq_purchasehub_quotation" model="ir.sequence">
            <field name="name">Quotation Number</field>
            <field name="code">purchasehub.quotation.sequence</field>
            <field name="prefix">QT</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Approval Number Sequence -->
        <record id="seq_purchasehub_approval" model="ir.sequence">
            <field name="name">Approval Number</field>
            <field name="code">purchasehub.approval.sequence</field>
            <field name="prefix">APR</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Purchase Order Sequence -->
        <record id="seq_purchasehub_po" model="ir.sequence">
            <field name="name">Purchase Order Number</field>
            <field name="code">purchasehub.po.sequence</field>
            <field name="prefix">PO</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Invoice Sequence -->
        <record id="seq_purchasehub_invoice" model="ir.sequence">
            <field name="name">Invoice Number</field>
            <field name="code">purchasehub.invoice.sequence</field>
            <field name="prefix">INV</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
